{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "noEmit": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@pageobjects/*": ["test/pageobjects/*"],
      "@helpers/*": ["test/helpers/*"],
      "@data/*": ["test/data/*"]
    },
    "types": [
      "node",
      "@wdio/globals/types",
      "@wdio/mocha-framework",
      "webdriverio"
    ]
  },
  "include": [
    "config/**/*.ts",
    "test/**/*.ts",
    "scripts/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
